  leading-tight tracking-tight
  opacity-0 animate-[fadeIn_0.8s_ease-in-out_forwards] [animation-delay:300ms]"> 
    cuatro </h2> </li>

  </ul>

  <ul>
  <li class="flex justify-start px-5 md:px-10 lg:px-16 xl:translate-x-[-500px]"> 
<h2 class="text-2xl md:text-3xl lg:text-4xl font-bold text-blue-900
  leading-tight tracking-tight
  opacity-0 animate-[fadeIn_0.8s_ease-in-out_forwards] [animation-delay:300ms]">
  cinco 

  </h2>
  </li>
   
</ul>



