---
import Layout from "../layouts/Layout.astro"
import '../styles/global.css'  

---

<Layout title="Curriculum">
  
  <section class="py-12 bg-transparent">
 <div class="Content px-12 md:px-14 lg:px-26 py-20 md:py-26">
		<h1 class="title md:ml-20 text-8xl font-bold text-blue-900 hover:text-blue-800 transition-colors duration-100 leading-[0.9] tracking-tight opacity-0 animate-[fadeIn_0.8s_ease-in-out_forwards]
    xl:translate-x-[-80px] lg:translate-x-[-160px] xl:mx-30 md:translate-x-[80px]">
  Pablo
  Andrés<br>
  León
</h1>
		<p class="text-sm mt-20 lg:max-w-xl ml-5 text-gray-500 leading-relaxed tracking-wide font-medium opacity-0 animate-[fadeIn_0.8s_ease-in-out_forwards] lg:translate-x-[-70px] xl:mx-30">
  Bienvenidos al sitio oficial del abogado Pablo Andrés León, especialista en Derecho Penal, 
  Derecho Penal de la Administración Pública y Derecho Penal Económico. 
  Se ofrece asesoramiento jurídico estratégico y defensa rigurosa, con un enfoque 
  personalizado en cada caso.
</p>
	</div>
  


<div class="relative mt-10 md:mt-0 lg:mt-[-100px] xl:mt-[-500px]">

  <div class="mx-auto max-w-7xl px-8 lg:px-10 flex justify-center lg:justify-end">

    <div class="relative w-full 
      max-w-[350px] 
      sm:max-w-[400px] 
      md:max-w-[400px] 
      lg:max-w-[300px] 
      xl:max-w-[380px]
      lg:-translate-y-90
      xl:translate-y-0
      opacity-0 animate-[fadeIn_0.8s_ease-in-out_forwards]">

      <img 
        src="/Photos/Picture1.jpg"
        alt="Pablo Andrés León - Abogado Penalista"
        class="w-full h-auto rounded-2xl shadow-2xl object-cover"
      />

    </div>

  </div>
</div>
</section>


<div class="bg-gray-200 py-8 px-50 md:px-100 lg:px-20 xl:px-170 max-w-screen-xl mx-auto">

<h2 class="content font-bold text-blue-900
text-lg md:text-xl lg:text-2xl
ml-0 md:ml-[-80px] lg:ml-[-600px]
py-12 md:py-20 lg:py-26
lg:-mt-70 xl:-mt-10
leading-tight tracking-tight
opacity-0 animate-[fadeIn_0.8s_ease-in-out_forwards] [animation-delay:300ms]">
  
</h2>
Experiencia
<nav>
<ul>
  <li> uno</li>
  <li>dos </li>
  <li> tres </li>
  <li>cuatro </li>
  <li> cinco </li>
   
</ul>



</nav>

<div class="">
  <p>Educacion</p>
</div>


</div>


  
</Layout>

